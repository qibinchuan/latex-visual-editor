{
  "name": "latex-visual-editor",
  "displayName": "LaTeX Visual Editor",
  "description": "A Visual LaTeX editor, inspired by Overleaf's visual editor.",
  "version": "0.1.0",
  "publisher": "cyndigan",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyndigan/latex-visual-editor.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onUri"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "latexVisualEditor.editor",
        "displayName": "LaTeX Visual Editor",
        "selector": [
          {
            "filenamePattern": "*.tex"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "latexVisualEditor.toggle",
        "title": "Toggle Visual Editor",
        "shortTitle": "Toggle Visual Editor",
        "icon": "$(eye)"
      },
      {
        "command": "latexVisualEditor.openVisual",
        "title": "LaTeX: Open Visual Editor"
      },
      {
        "command": "latexVisualEditor.openSource",
        "title": "LaTeX: Open Source Editor"
      },
      {
        "command": "latexVisualEditor.insertFigure",
        "title": "LaTeX: Insert Figure"
      },
      {
        "command": "latexVisualEditor.insertTable",
        "title": "LaTeX: Insert Table"
      },
      {
        "command": "latexVisualEditor.fold",
        "title": "LaTeX: Fold"
      },
      {
        "command": "latexVisualEditor.unfold",
        "title": "LaTeX: Unfold"
      },
      {
        "command": "latexVisualEditor.foldAll",
        "title": "LaTeX: Fold All"
      },
      {
        "command": "latexVisualEditor.unfoldAll",
        "title": "LaTeX: Unfold All"
      },
      {
        "command": "latexVisualEditor.toggleFold",
        "title": "LaTeX: Toggle Fold"
      },
      {
        "command": "latexVisualEditor.foldRecursively",
        "title": "LaTeX: Fold Recursively"
      },
      {
        "command": "latexVisualEditor.unfoldRecursively",
        "title": "LaTeX: Unfold Recursively"
      },
      {
        "command": "latexVisualEditor.toggleFoldRecursively",
        "title": "LaTeX: Toggle Fold Recursively"
      },
      {
        "command": "latexVisualEditor.foldAllBlockComments",
        "title": "LaTeX: Fold All Block Comments"
      },
      {
        "command": "latexVisualEditor.foldAllMarkerRegions",
        "title": "LaTeX: Fold All Regions"
      },
      {
        "command": "latexVisualEditor.unfoldAllMarkerRegions",
        "title": "LaTeX: Unfold All Regions"
      },
      {
        "command": "latexVisualEditor.foldAllExcept",
        "title": "LaTeX: Fold All Except Selected"
      },
      {
        "command": "latexVisualEditor.unfoldAllExcept",
        "title": "LaTeX: Unfold All Except Selected"
      },
      {
        "command": "latexVisualEditor.foldLevel1",
        "title": "LaTeX: Fold Level 1"
      },
      {
        "command": "latexVisualEditor.foldLevel2",
        "title": "LaTeX: Fold Level 2"
      },
      {
        "command": "latexVisualEditor.foldLevel3",
        "title": "LaTeX: Fold Level 3"
      },
      {
        "command": "latexVisualEditor.foldLevel4",
        "title": "LaTeX: Fold Level 4"
      },
      {
        "command": "latexVisualEditor.foldLevel5",
        "title": "LaTeX: Fold Level 5"
      },
      {
        "command": "latexVisualEditor.foldLevel6",
        "title": "LaTeX: Fold Level 6"
      },
      {
        "command": "latexVisualEditor.foldLevel7",
        "title": "LaTeX: Fold Level 7"
      },
      {
        "command": "latexVisualEditor.createFoldingRangeFromSelection",
        "title": "LaTeX: Create Folding Range from Selection"
      },
      {
        "command": "latexVisualEditor.removeManualFoldingRanges",
        "title": "LaTeX: Remove Manual Folding Ranges"
      },
      {
        "command": "latexVisualEditor.refreshWebviews",
        "title": "LaTeX: Refresh Visual Editor Webviews"
      },
      {
        "command": "latexVisualEditor.viewPdf",
        "title": "View LaTeX PDF file",
        "category": "LaTeX Workshop",
        "icon": "$(open-preview)"
      }
    ],
    "keybindings": [
      {
        "command": "latexVisualEditor.consumeShortcut",
        "key": "ctrl+a",
        "mac": "cmd+a",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.copy",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor && editorFocus"
      },
      {
        "command": "latexVisualEditor.consumeShortcut",
        "key": "ctrl+z",
        "mac": "cmd+z",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.consumeShortcut",
        "key": "ctrl+y",
        "mac": "cmd+y",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.consumeShortcut",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.consumeShortcut",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.consumeShortcut",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.consumeShortcut",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "config.latexVisualEditor.useOverleafKeybindings && activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.fold",
        "key": "ctrl+shift+[",
        "mac": "cmd+alt+[",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.unfold",
        "key": "ctrl+shift+]",
        "mac": "cmd+alt+]",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldAll",
        "key": "ctrl+k ctrl+0",
        "mac": "cmd+k cmd+0",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.unfoldAll",
        "key": "ctrl+k ctrl+j",
        "mac": "cmd+k cmd+j",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.toggleFold",
        "key": "ctrl+k ctrl+l",
        "mac": "cmd+k cmd+l",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldRecursively",
        "key": "ctrl+k ctrl+[",
        "mac": "cmd+k cmd+[",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.unfoldRecursively",
        "key": "ctrl+k ctrl+]",
        "mac": "cmd+k cmd+]",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.toggleFoldRecursively",
        "key": "ctrl+k ctrl+shift+l",
        "mac": "cmd+k cmd+shift+l",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldAllBlockComments",
        "key": "ctrl+k ctrl+/",
        "mac": "cmd+k cmd+/",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldAllMarkerRegions",
        "key": "ctrl+k ctrl+8",
        "mac": "cmd+k cmd+8",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.unfoldAllMarkerRegions",
        "key": "ctrl+k ctrl+9",
        "mac": "cmd+k cmd+9",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldAllExcept",
        "key": "ctrl+k ctrl+-",
        "mac": "cmd+k cmd+-",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.unfoldAllExcept",
        "key": "ctrl+k ctrl+=",
        "mac": "cmd+k cmd+=",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldLevel1",
        "key": "ctrl+k ctrl+1",
        "mac": "cmd+k cmd+1",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldLevel2",
        "key": "ctrl+k ctrl+2",
        "mac": "cmd+k cmd+2",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldLevel3",
        "key": "ctrl+k ctrl+3",
        "mac": "cmd+k cmd+3",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldLevel4",
        "key": "ctrl+k ctrl+4",
        "mac": "cmd+k cmd+4",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldLevel5",
        "key": "ctrl+k ctrl+5",
        "mac": "cmd+k cmd+5",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldLevel6",
        "key": "ctrl+k ctrl+6",
        "mac": "cmd+k cmd+6",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.foldLevel7",
        "key": "ctrl+k ctrl+7",
        "mac": "cmd+k cmd+7",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.createFoldingRangeFromSelection",
        "key": "ctrl+k ctrl+,",
        "mac": "cmd+k cmd+,",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.removeManualFoldingRanges",
        "key": "ctrl+k ctrl+.",
        "mac": "cmd+k cmd+.",
        "when": "activeCustomEditorId == latexVisualEditor.editor"
      },
      {
        "command": "latexVisualEditor.workshopBuild",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "activeCustomEditorId == latexVisualEditor.editor && !config.latex-workshop.bind.altKeymap.enabled && !virtualWorkspace"
      },
      {
        "command": "latexVisualEditor.workshopSyncTeX",
        "key": "ctrl+alt+j",
        "mac": "cmd+alt+j",
        "when": "activeCustomEditorId == latexVisualEditor.editor && !config.latex-workshop.bind.altKeymap.enabled"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "latexVisualEditor.toggle",
          "when": "resourceExtname == .tex",
          "group": "navigation@20"
        },
        {
          "command": "latexVisualEditor.viewPdf",
          "when": "activeCustomEditorId == latexVisualEditor.editor && resourceExtname == .tex",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "LaTeX Visual Editor",
      "properties": {
        "latexVisualEditor.assetsDirectory": {
          "type": "string",
          "default": "assets",
          "description": "Workspace-relative directory used when copying inserted images."
        },
        "latexVisualEditor.rememberMode": {
          "type": "boolean",
          "default": true,
          "description": "Remember visual mode separately for each LaTeX file in the workspace."
        },
        "latexVisualEditor.persistToggleAcrossTexFiles": {
          "type": "boolean",
          "default": true,
          "description": "Apply the current source/visual toggle choice when opening other LaTeX files."
        },
        "latexVisualEditor.useOverleafKeybindings": {
          "type": "boolean",
          "default": true,
          "description": "Use Overleaf keyboard shortcuts in the visual editor. Disable this to leave conflicting shortcuts to VS Code."
        },
        "latexVisualEditor.maxImagePreviewBytes": {
          "type": "number",
          "default": 20971520,
          "minimum": 1048576,
          "description": "Maximum image size in bytes that the visual editor previews."
        },
        "latexVisualEditor.syntaxValidation": {
          "type": "boolean",
          "default": true,
          "description": "Enable syntax-aware visual rendering."
        }
      }
    }
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "generate:parser": "node scripts/generate-parser.mjs",
    "build": "npm run generate:parser && node scripts/build.mjs",
    "watch": "npm run generate:parser && node scripts/build.mjs --watch",
    "refresh:webviews": "npm run build && node scripts/refresh-webviews.mjs",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run generate:parser",
    "test": "vitest run",
    "test:e2e:shortcuts": "node scripts/test-keyboard-shortcuts.mjs",
    "test:e2e:shortcuts:disabled": "node scripts/test-keyboard-shortcuts.mjs --disabled",
    "test:e2e:table-handling": "node scripts/test-table-handling.mjs",
    "test:e2e:latex-workshop-shortcuts": "node scripts/test-latex-workshop-shortcuts.mjs",
    "test:e2e:visual-auto-build": "node scripts/test-visual-auto-build.mjs",
    "check": "npm run typecheck && npm test",
    "vscode:prepublish": "npm run check && npm run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.7",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@lezer/common": "^1.2.3",
    "@lezer/highlight": "^1.2.1",
    "@lezer/lr": "^1.4.2",
    "@overleaf/o-error": "^3.4.0",
    "lodash": "^4.17.21",
    "mathjax": "^4.1.2",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@lezer/generator": "^1.7.3",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.15.3",
    "@types/vscode": "^1.95.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
